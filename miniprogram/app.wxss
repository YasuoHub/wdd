/**app.wxss**/
/* 全局样式 - 蓝天白云主题 */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1E293B;
  background-color: #F0F9FF;
  box-sizing: border-box;
}

/* 重置常用元素的 box-sizing */
view, text, image, button, input, textarea, scroll-view {
  box-sizing: border-box;
}

/* 容器 */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 主色调 - 天空蓝 */
.primary-color {
  color: #0EA5E9;
}

.primary-bg {
  background: linear-gradient(135deg, #38BDF8 0%, #0EA5E9 100%);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #38BDF8 0%, #0EA5E9 100%);
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.3);
  transition: all 0.3s ease;
}

.btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(14, 165, 233, 0.2);
}

.btn::after {
  border: none;
}

.btn-outline {
  color: #0EA5E9;
  background: #fff;
  border: 2rpx solid #0EA5E9;
  box-shadow: none;
}

.btn-small {
  height: 64rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
  border: 2rpx solid rgba(224, 242, 254, 0.8);
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #E0F2FE;
}

.list-item:last-child {
  border-bottom: none;
}

/* 文本样式 */
.text-primary {
  color: #1E293B;
}

.text-secondary {
  color: #64748B;
}

.text-tertiary {
  color: #94A3B8;
}

.text-sky {
  color: #0EA5E9;
}

.text-sunset {
  color: #FB923C;
}

/* 字体大小 */
.font-xs {
  font-size: 24rpx;
}

.font-sm {
  font-size: 26rpx;
}

.font-base {
  font-size: 28rpx;
}

.font-lg {
  font-size: 32rpx;
}

.font-xl {
  font-size: 36rpx;
}

.font-xxl {
  font-size: 48rpx;
}

/* 大字体模式 */
.large-font .font-xs {
  font-size: 28rpx;
}

.large-font .font-sm {
  font-size: 30rpx;
}

.large-font .font-base {
  font-size: 34rpx;
}

.large-font .font-lg {
  font-size: 38rpx;
}

.large-font .font-xl {
  font-size: 42rpx;
}

.large-font .font-xxl {
  font-size: 54rpx;
}

.large-font .btn {
  height: 100rpx;
  font-size: 36rpx;
}

.large-font .card {
  padding: 40rpx;
}

/* 布局工具 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.text-center {
  text-align: center;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #94A3B8;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  color: #94A3B8;
  font-size: 28rpx;
}

/* 隐藏 */
.hidden {
  display: none;
}
