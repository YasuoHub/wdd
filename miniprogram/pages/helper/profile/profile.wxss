/* pages/helper/profile/profile.wxss */

page {
  background-color: #F0F9FF;
  min-height: 100vh;
}

.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 背景 */
.bg-blue {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(180deg, #0EA5E9 0%, #38BDF8 60%, #F0F9FF 100%);
  z-index: -1;
}

.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
}

.cloud-1 {
  width: 120rpx;
  height: 60rpx;
  top: 80rpx;
  left: 10%;
  animation: float 8s ease-in-out infinite;
}

.cloud-2 {
  width: 180rpx;
  height: 90rpx;
  top: 40rpx;
  right: 15%;
  animation: float 10s ease-in-out infinite 2s;
}

.cloud-3 {
  width: 100rpx;
  height: 50rpx;
  top: 150rpx;
  left: 60%;
  animation: float 7s ease-in-out infinite 1s;
}

@keyframes float {
  0%, 100% { transform: translateY(0rpx); }
  50% { transform: translateY(-15rpx); }
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(14, 165, 233, 0.2);
  border-top-color: #0EA5E9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}

/* 页面标题 */
.page-header {
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  line-height: 1.3;
}

@media screen and (max-width: 375px) {
  .header-title {
    font-size: 34rpx;
  }
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

/* 卡片区域 */
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
  box-sizing: border-box;
}

@media screen and (max-width: 375px) {
  .section-card {
    padding: 24rpx;
  }
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  flex: 1;
}

.section-required {
  font-size: 32rpx;
  color: #EF4444;
}

.section-desc {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 24rpx;
}

/* 帮助类型网格 - 自适应布局 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

/* 小屏幕使用2列 */
@media screen and (max-width: 375px) {
  .type-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 8rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.2s ease;
  min-height: 120rpx;
  box-sizing: border-box;
}

.type-item:active {
  transform: scale(0.98);
  background: #F0F9FF;
}

.type-item.selected {
  background: linear-gradient(135deg, #DBEAFE 0%, #EFF6FF 100%);
  border-color: #0EA5E9;
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.2);
  transform: scale(1.02);
}

.type-item .type-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.type-item .type-name {
  font-size: 24rpx;
  color: #374151;
}

.type-item.selected .type-name {
  color: #0EA5E9;
  font-weight: 600;
}

.check-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #0EA5E9;
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.selected-count {
  margin-top: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #0EA5E9;
  font-weight: 500;
}

/* 位置列表 */
.location-list {
  margin-bottom: 20rpx;
}

.location-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.location-info {
  flex: 1;
  min-width: 0;
}

.location-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-address {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-radius {
  font-size: 24rpx;
  color: #0EA5E9;
  font-weight: 500;
}

.location-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
  align-items: center;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.action-btn.edit {
  color: #0EA5E9;
  background: #F0F9FF;
}

.action-btn.delete {
  color: #EF4444;
  background: #FEF2F2;
}

/* 添加位置按钮 */
.add-location-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border: 2rpx dashed #CBD5E1;
  border-radius: 16rpx;
  background: #F8FAFC;
}

.add-icon {
  font-size: 36rpx;
  color: #0EA5E9;
  margin-right: 12rpx;
  font-weight: 600;
}

.add-text {
  font-size: 28rpx;
  color: #0EA5E9;
  font-weight: 500;
}

/* 位置数量上限提示 */
.location-limit-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  background: #ECFDF5;
  border-radius: 16rpx;
  border: 2rpx solid #A7F3D0;
}

.location-limit-tip .tip-icon {
  font-size: 28rpx;
  color: #10B981;
  margin-right: 8rpx;
}

.location-limit-tip .tip-text {
  font-size: 26rpx;
  color: #065F46;
}

/* 提示区域 */
.tips-section {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

.tip-text {
  font-size: 24rpx;
  color: #92400E;
  line-height: 1.5;
  flex: 1;
}

/* 提交区域 */
.submit-section {
  padding: 20rpx 0;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin: 0;
  box-shadow: 0 8rpx 20rpx rgba(14, 165, 233, 0.3);
}

.submit-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

/* 位置编辑弹窗 - 自适应 */
.location-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 85%;
  max-width: 600rpx;
  min-width: 280px;
  background: #fff;
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.modal-close {
  font-size: 40rpx;
  color: #9CA3AF;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 30rpx;
}

.location-preview {
  background: #F0F9FF;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.preview-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.preview-address {
  font-size: 24rpx;
  color: #6B7280;
}

/* 范围设置 */
.radius-section {
  margin-top: 20rpx;
}

.radius-label {
  display: block;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
}

.radius-value {
  text-align: center;
  margin-bottom: 20rpx;
}

.radius-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #0EA5E9;
}

.radius-unit {
  font-size: 28rpx;
  color: #6B7280;
  margin-left: 8rpx;
}

.radius-slider {
  margin: 20rpx 0;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 弹窗底部 */
.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx 16rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin: 0;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: #F3F4F6;
  color: #6B7280;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #fff;
}

/* 大字体模式 */
.large-font .header-title {
  font-size: 44rpx;
}

@media screen and (max-width: 375px) {
  .large-font .header-title {
    font-size: 38rpx;
  }
}

.large-font .section-title {
  font-size: 36rpx;
}

.large-font .type-item .type-name {
  font-size: 26rpx;
}

.large-font .location-name {
  font-size: 32rpx;
}

.large-font .submit-btn {
  font-size: 34rpx;
}

/* 超大屏幕适配 */
@media screen and (min-width: 500px) {
  .type-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}