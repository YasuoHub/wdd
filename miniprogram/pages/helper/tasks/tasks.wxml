<!--pages/helper/tasks/tasks.wxml-->
<view class="container {{isLargeFont ? 'large-font' : ''}}">
  <!-- 背景 -->
  <view class="bg-blue">
    <view class="cloud cloud-1"></view>
    <view class="cloud cloud-2"></view>
    <view class="cloud cloud-3"></view>
  </view>
  
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">我的任务</text>
    <text class="header-desc">管理和查看您接受的所有任务</text>
  </view>
  
  <!-- 标签切换 -->
  <view class="tab-section">
    <view class="tab-list">
      <view 
        class="tab-item {{currentTab === item.key ? 'active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="key"
        bindtap="switchTab"
        data-key="{{item.key}}"
      >
        <text class="tab-icon">{{item.icon}}</text>
        <text class="tab-name">{{item.name}}</text>
      </view>
    </view>
  </view>
  
  <!-- 任务列表 -->
  <view class="task-section">
    <!-- 加载中 -->
    <view class="loading-container" wx:if="{{loading && taskList.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && taskList.length === 0}}">
      <view class="empty-icon">📋</view>
      <text class="empty-title">暂无{{currentTab === 'executing' ? '进行中' : currentTab === 'completed' ? '已完成' : '已取消'}}的任务</text>
      <text class="empty-desc">去帮助者首页接取新任务吧</text>
      <button class="go-btn" bindtap="goToHome">去接单</button>
    </view>
    
    <!-- 任务卡片列表 -->
    <view class="task-list" wx:if="{{taskList.length > 0}}">
      <view 
        class="task-card"
        wx:for="{{taskList}}"
        wx:key="_id"
        bindtap="viewTaskDetail"
        data-id="{{item._id}}"
      >
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="type-tag">
            <text class="type-icon">{{item.typeIcon || '📋'}}</text>
            <text class="type-name">{{item.typeName || '其他'}}</text>
          </view>
          <view class="status-badge {{item.statusClass}}">
            <text>{{item.statusText}}</text>
          </view>
        </view>
        
        <!-- 位置信息 -->
        <view class="location-box">
          <text class="location-icon">📍</text>
          <text class="location-name">{{item.location && item.location.name || '未知位置'}}</text>
        </view>
        
        <!-- 描述 -->
        <view class="card-body">
          <text class="task-desc">{{item.description || '暂无描述'}}</text>
        </view>
        
        <!-- 卡片底部 -->
        <view class="card-footer">
          <view class="footer-left">
            <view class="time-info">
              <text class="time-label">发布时间：</text>
              <text class="time-value">{{item.formattedTime}}</text>
            </view>
          </view>
          <view class="footer-right">
            <view class="bounty-box">
              <text class="bounty-icon">💎</text>
              <text class="bounty-num">{{item.points || 0}}</text>
            </view>
          </view>
        </view>
        
        <!-- 操作按钮区 -->
        <view class="action-section" wx:if="{{item.status === 'executing'}}">
          <button 
            class="action-btn chat-btn"
            catchtap="contactSeeker"
            data-id="{{item._id}}"
          >
            <text class="btn-icon">💬</text>
            <text>联系求助者</text>
          </button>
          <button 
            class="action-btn complete-btn"
            catchtap="completeTask"
            data-id="{{item._id}}"
          >
            <text class="btn-icon">✅</text>
            <text>完成任务</text>
          </button>
        </view>
      </view>
      
      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{hasMore}}">
        <text wx:if="{{loading}}">加载中...</text>
        <text wx:else>上拉加载更多</text>
      </view>
      
      <view class="no-more" wx:if="{{!hasMore && taskList.length > 5}}">
        <text>没有更多了</text>
      </view>
    </view>
  </view>
</view>