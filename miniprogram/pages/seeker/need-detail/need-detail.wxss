/* pages/seeker/need-detail/need-detail.wxss */

page {
  background-color: #F0F9FF;
  min-height: 100vh;
}

.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 背景 */
.bg-blue {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(180deg, #0EA5E9 0%, #38BDF8 60%, #F0F9FF 100%);
  z-index: -1;
}

.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
}

.cloud-1 {
  width: 120rpx;
  height: 60rpx;
  top: 80rpx;
  left: 10%;
  animation: float 8s ease-in-out infinite;
}

.cloud-2 {
  width: 180rpx;
  height: 90rpx;
  top: 40rpx;
  right: 15%;
  animation: float 10s ease-in-out infinite 2s;
}

.cloud-3 {
  width: 100rpx;
  height: 50rpx;
  top: 150rpx;
  left: 60%;
  animation: float 7s ease-in-out infinite 1s;
}

@keyframes float {
  0%, 100% { transform: translateY(0rpx); }
  50% { transform: translateY(-15rpx); }
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(14, 165, 233, 0.2);
  border-top-color: #0EA5E9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}

/* 状态卡片 */
.status-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
}

.status-matching {
  background: #FEF3C7;
  color: #92400E;
}

.status-executing {
  background: #DBEAFE;
  color: #1E40AF;
}

.status-completed {
  background: #D1FAE5;
  color: #065F46;
}

.status-cancelled {
  background: #E5E7EB;
  color: #374151;
}

.status-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.status-text {
  font-size: 28rpx;
  font-weight: 600;
}

.need-no {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.copy-icon {
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* 详情卡片 */
.detail-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
}

.type-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.type-tag {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  border-radius: 24rpx;
}

.type-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.type-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.time-text {
  font-size: 24rpx;
  color: #999;
}

.desc-section {
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.location-section {
  margin-bottom: 24rpx;
}

.section-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.location-box {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
}

.location-main {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.location-detail {
  font-size: 24rpx;
  color: #999;
}

.images-section {
  margin-top: 24rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ref-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

/* 悬赏卡片 */
.bounty-card {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(14, 165, 233, 0.25);
}

.bounty-row {
  display: flex;
  align-items: center;
}

.bounty-item {
  flex: 1;
  text-align: center;
}

.divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.bounty-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.bounty-value {
  display: flex;
  align-items: center;
  justify-content: center;
}

.bounty-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.bounty-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.time-warning {
  font-size: 36rpx;
}

.overdue {
  color: #FEF3C7;
}

/* 帮助者卡片 */
.helper-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
}

.helper-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.helper-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.helper-status {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #10B981;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.status-dot.active {
  background: #10B981;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.helper-info {
  display: flex;
  align-items: center;
}

.helper-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.helper-detail {
  flex: 1;
}

.helper-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.helper-meta {
  display: flex;
  gap: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
  background: #F0F9FF;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.chat-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: #0EA5E9;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin: 0;
  line-height: 1;
}

.chat-btn::after {
  border: none;
}

/* 等待提示 */
.waiting-tip {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.tip-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.tip-title {
  display: block;
  font-size: 30rpx;
  color: #92400E;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tip-desc {
  display: block;
  font-size: 24rpx;
  color: #B45309;
}

/* 操作区 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin: 0;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.cancel-btn {
  background: #FEE2E2;
  color: #DC2626;
}

.complete-btn {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.3);
}

.review-btn {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(245, 158, 11, 0.3);
}

.support-btn {
  background: #F3F4F6;
  color: #6B7280;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

/* 已完成状态 */
.completed-section {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.completed-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.completed-title {
  display: block;
  font-size: 32rpx;
  color: #065F46;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.completed-desc {
  display: block;
  font-size: 26rpx;
  color: #059669;
}

/* 底部操作 */
.bottom-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.secondary-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  background: #fff;
  color: #0EA5E9;
  border: 2rpx solid #0EA5E9;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin: 0;
  line-height: 1;
}

.secondary-btn::after {
  border: none;
}

.home-btn {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #fff;
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.primary-btn {
  width: 300rpx;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin: 0;
  box-shadow: 0 8rpx 20rpx rgba(14, 165, 233, 0.3);
}

.primary-btn::after {
  border: none;
}

/* 大字体模式 */
.large-font .desc-text {
  font-size: 34rpx;
}

.large-font .helper-name {
  font-size: 36rpx;
}

.large-font .action-btn {
  font-size: 34rpx;
}

.large-font .tip-title,
.large-font .completed-title {
  font-size: 34rpx;
}