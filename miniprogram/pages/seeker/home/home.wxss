/**miniprogram/pages/seeker/home/home.wxss**/
/* 求助者首页样式 - 蓝色主题 */

.container {
  min-height: 100vh;
  background: #F0F9FF;
}

/* 顶部蓝色区域 */
.header-section {
  background: linear-gradient(135deg, #38BDF8 0%, #0EA5E9 50%, #0284C7 100%);
  padding: 60rpx 32rpx 40rpx;
  position: relative;
  overflow: hidden;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(14, 165, 233, 0.2);
}

.cloud {
  position: absolute;
  opacity: 0.3;
  animation: float 8s ease-in-out infinite;
}

.cloud-1 {
  top: 20rpx;
  right: 10%;
  font-size: 60rpx;
  animation-delay: 0s;
}

.cloud-2 {
  top: 80rpx;
  left: 5%;
  font-size: 48rpx;
  animation-delay: 3s;
}

@keyframes float {
  0%, 100% { transform: translateY(0rpx); }
  50% { transform: translateY(-10rpx); }
}

.header-content {
  position: relative;
  z-index: 1;
}

.welcome-text {
  margin-bottom: 32rpx;
}

.greeting {
  display: block;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.subtitle {
  display: block;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.stat-value.highlight {
  color: #FCD34D;
  text-shadow: 0 0 20rpx rgba(252, 211, 77, 0.5);
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 主要内容区域 */
.main-content {
  padding: 32rpx;
  margin-top: -20rpx;
}

/* 发布需求大按钮 */
.publish-section {
  margin-bottom: 32rpx;
}

.publish-card {
  background: linear-gradient(135deg, #38BDF8 0%, #0EA5E9 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(14, 165, 233, 0.3);
  transition: all 0.3s ease;
}

.publish-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.25);
}

.publish-bg {
  position: absolute;
  top: -50%;
  right: -30%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.publish-content {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.publish-icon-wrap {
  position: relative;
  margin-right: 24rpx;
}

.publish-icon {
  font-size: 72rpx;
  position: relative;
  z-index: 1;
}

.icon-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx;
  height: 100rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.5; }
}

.publish-text {
  flex: 1;
}

.publish-title {
  display: block;
  color: #fff;
  font-weight: 800;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.publish-desc {
  color: rgba(255, 255, 255, 0.95);
}

.publish-arrow {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

.publish-hint {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(255,255,255,0.2);
}

.hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 快速类型选择 */
.quick-types-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
}

.section-more {
  font-size: 26rpx;
  color: #0EA5E9;
  font-weight: 600;
}

.types-scroll {
  white-space: nowrap;
}

.types-list {
  display: inline-flex;
  gap: 20rpx;
  padding: 8rpx 4rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.08);
  border: 2rpx solid #E0F2FE;
  transition: all 0.3s ease;
  min-width: 140rpx;
}

.type-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(14, 165, 233, 0.15);
}

.type-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: 2rpx solid;
}

.type-icon {
  font-size: 44rpx;
}

.type-name {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

/* 需求列表 */
.needs-section {
  margin-bottom: 32rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  font-size: 32rpx;
}

.view-all {
  font-size: 26rpx;
  color: #0EA5E9;
  font-weight: 600;
}

.needs-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.need-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.06);
  border: 2rpx solid #E0F2FE;
  transition: all 0.3s ease;
  opacity: 0;
  transform: translateY(20rpx);
  animation: slideIn 0.5s ease forwards;
}

.need-card.show {
  opacity: 1;
  transform: translateY(0);
}

@keyframes slideIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.need-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(14, 165, 233, 0.1);
}

.need-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.need-type {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.type-emoji {
  font-size: 32rpx;
}

.type-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.need-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.need-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
}

.location-icon {
  font-size: 24rpx;
}

.location-text {
  font-size: 26rpx;
  color: #64748B;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.need-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.need-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #94A3B8;
}

.time-icon {
  font-size: 20rpx;
}

.need-points {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: linear-gradient(135deg, #E0F2FE 0%, #F0F9FF 100%);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.points-icon {
  font-size: 24rpx;
}

.points-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #0EA5E9;
}

.load-more, .no-more {
  text-align: center;
  padding: 24rpx;
  color: #94A3B8;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.06);
  border: 2rpx solid #E0F2FE;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  color: #475569;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 32rpx;
  text-align: center;
}

.empty-btn {
  background: linear-gradient(135deg, #38BDF8 0%, #0EA5E9 100%);
  color: #fff;
  padding: 24rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.3);
}

.empty-btn::after {
  border: none;
}

/* 帮助提示 */
.help-section {
  margin-bottom: 40rpx;
}

.help-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid #FCD34D;
}

.help-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.help-content {
  flex: 1;
}

.help-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 8rpx;
}

.help-text {
  font-size: 24rpx;
  color: #B45309;
}

/* 大字体模式 */
.large-font .greeting {
  font-size: 48rpx;
}

.large-font .stat-value {
  font-size: 48rpx;
}

.large-font .publish-icon {
  font-size: 88rpx;
}

.large-font .section-title {
  font-size: 36rpx;
}

.large-font .type-icon-wrap {
  width: 100rpx;
  height: 100rpx;
}

.large-font .type-name {
  font-size: 28rpx;
}
