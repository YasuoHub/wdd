<!--miniprogram/pages/index/index.wxml-->
<view class="container {{isLargeFont ? 'large-font' : ''}}">
  <!-- 蓝天白云背景区域 -->
  <view class="sky-section">
    <!-- 漂浮的云朵 -->
    <view class="cloud cloud-1">☁️</view>
    <view class="cloud cloud-2">☁️</view>
    <view class="cloud cloud-3">✨</view>
    <view class="sun">☀️</view>
    
    <!-- 品牌区域 -->
    <view class="brand-area">
      <view class="logo-wrap">
        <text class="logo-icon">☁️</text>
        <text class="app-name {{isLargeFont ? 'font-xxl' : 'font-xl'}}">问当地</text>
      </view>
      <text class="slogan {{isLargeFont ? 'font-lg' : 'font-base'}}">异地信息 · 即时获取</text>
    </view>
    
    <!-- 登录后显示的用户信息卡片 -->
    <view class="user-card" wx:if="{{hasUserInfo}}">
      <view class="user-main">
        <view class="avatar-wrap">
          <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"/>
          <view class="online-dot"></view>
        </view>
        <view class="user-info">
          <text class="greeting">嗨，{{userInfo.nickname}} 👋</text>
          <view class="points-pill" bindtap="goToPoints">
            <text class="pill-icon">💎</text>
            <text class="pill-text">{{userInfo.points.balance}} 积分</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 登录区域（未登录时显示）-->
  <view class="login-area" wx:if="{{!hasUserInfo}}">
    <view class="welcome-card">
      <view class="card-decoration">
        <text class="deco-icon">🌈</text>
      </view>
      <text class="welcome-title {{isLargeFont ? 'font-xl' : 'font-lg'}}">欢迎来到问当地</text>
      <text class="welcome-subtitle {{isLargeFont ? 'font-base' : 'font-sm'}}">互帮互助，温暖同行 ☀️</text>
      <button
        class="btn-start {{isLargeFont ? 'btn-large' : ''}}"
        bindtap="getUserProfile"
      >
        <text class="start-icon">🚀</text>
        <text>一键开启</text>
      </button>
    </view>
  </view>

  <!-- 功能区域（登录后显示）-->
  <view class="features-area" wx:if="{{hasUserInfo}}">
    <!-- 我要求助卡片 -->
    <view class="feature-card seeker-card" bindtap="goToSeeker">
      <view class="card-visual blue">
        <view class="visual-circle">
          <text class="visual-icon">📍</text>
        </view>
        <view class="visual-bg"></view>
      </view>
      <view class="card-content">
        <text class="card-title {{isLargeFont ? 'font-xl' : 'font-lg'}}">我要求助</text>
        <text class="card-desc {{isLargeFont ? 'font-base' : 'font-sm'}}">快速获取异地实时信息</text>
      </view>
      <view class="card-action">
        <text class="action-text">去发布</text>
        <text class="action-arrow">→</text>
      </view>
    </view>

    <!-- 我要帮助卡片 -->
    <view class="feature-card helper-card" bindtap="goToHelper">
      <view class="card-visual orange">
        <view class="visual-circle">
          <text class="visual-icon">💰</text>
        </view>
        <view class="visual-bg"></view>
      </view>
      <view class="card-content">
        <text class="card-title {{isLargeFont ? 'font-xl' : 'font-lg'}}">我要帮助</text>
        <text class="card-desc {{isLargeFont ? 'font-base' : 'font-sm'}}">利用碎片时间赚取积分</text>
      </view>
      <view class="card-action">
        <text class="action-text">去接单</text>
        <text class="action-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 数据统计区域 -->
  <view class="stats-area" wx:if="{{hasUserInfo}}">
    <view class="stats-card">
      <view class="stat-item">
        <view class="stat-icon-wrap blue">
          <text class="stat-icon">📝</text>
        </view>
        <text class="stat-value {{isLargeFont ? 'font-xl' : 'font-lg'}}">{{(userInfo.seekerInfo && userInfo.seekerInfo.totalRequests) || 0}}</text>
        <text class="stat-label {{isLargeFont ? 'font-base' : 'font-sm'}}">发布需求</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon-wrap green">
          <text class="stat-icon">✅</text>
        </view>
        <text class="stat-value {{isLargeFont ? 'font-xl' : 'font-lg'}}">{{(userInfo.helperInfo && userInfo.helperInfo.completedTasks) || 0}}</text>
        <text class="stat-label {{isLargeFont ? 'font-base' : 'font-sm'}}">完成任务</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon-wrap pink">
          <text class="stat-icon">🎁</text>
        </view>
        <text class="stat-value {{isLargeFont ? 'font-xl' : 'font-lg'}}">{{(userInfo.pointsStats && userInfo.pointsStats.inviteCount) || 0}}</text>
        <text class="stat-label {{isLargeFont ? 'font-base' : 'font-sm'}}">邀请好友</text>
      </view>
    </view>
  </view>

  <!-- 底部提示区域 -->
  <view class="hints-area">
    <view class="hint-chip">
      <text class="chip-emoji">🎉</text>
      <text class="chip-text">新用户送100积分</text>
    </view>
    <view class="hint-chip">
      <text class="chip-emoji">✨</text>
      <text class="chip-text">完善信息再送30</text>
    </view>
  </view>
</view>
