/**miniprogram/pages/index/index.wxss**/
/* 首页样式 - 蓝天白云主题 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F9FF 0%, #E0F2FE 100%);
  padding: 0;
  position: relative;
}

/* 蓝天白云顶部区域 */
.sky-section {
  background: linear-gradient(135deg, #38BDF8 0%, #0EA5E9 50%, #0284C7 100%);
  border-radius: 0 0 48rpx 48rpx;
  padding: 80rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(14, 165, 233, 0.2);
}

/* 漂浮的云朵装饰 */
.cloud {
  position: absolute;
  opacity: 0.4;
  animation: float 6s ease-in-out infinite;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
}

.cloud-1 {
  top: 30rpx;
  left: 5%;
  font-size: 60rpx;
  animation-delay: 0s;
}

.cloud-2 {
  top: 80rpx;
  right: 8%;
  font-size: 48rpx;
  animation-delay: 2s;
  opacity: 0.3;
}

.cloud-3 {
  top: 120rpx;
  left: 15%;
  font-size: 32rpx;
  animation-delay: 4s;
  opacity: 0.5;
}

.sun {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  font-size: 48rpx;
  animation: rotate 20s linear infinite;
  opacity: 0.8;
}

@keyframes float {
  0%, 100% { transform: translateY(0rpx); }
  50% { transform: translateY(-15rpx); }
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 品牌区域 */
.brand-area {
  text-align: center;
  position: relative;
  z-index: 1;
}

.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
}

.logo-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.app-name {
  color: #fff;
  font-weight: 800;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.slogan {
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 4rpx;
  font-weight: 400;
}

/* 用户信息卡片 */
.user-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.user-main {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.online-dot {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  width: 24rpx;
  height: 24rpx;
  background: #34D399;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.user-info {
  flex: 1;
}

.greeting {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 12rpx;
}

.points-pill {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #38BDF8 0%, #0EA5E9 100%);
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.3);
}

.pill-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.pill-text {
  color: #fff;
  font-weight: 700;
  font-size: 26rpx;
}

/* 登录区域 */
.login-area {
  padding: 40rpx;
}

.welcome-card {
  background: #fff;
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(14, 165, 233, 0.12),
    0 2rpx 8rpx rgba(14, 165, 233, 0.06);
  border: 2rpx solid #E0F2FE;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.card-decoration {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.deco-icon {
  font-size: 48rpx;
  opacity: 0.6;
}

.welcome-title {
  display: block;
  color: #0EA5E9;
  font-weight: 800;
  margin-bottom: 16rpx;
  margin-top: 20rpx;
}

.welcome-subtitle {
  display: block;
  color: #64748B;
  margin-bottom: 40rpx;
}

.btn-start {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #38BDF8 0%, #0EA5E9 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.35);
  transition: all 0.3s ease;
}

.btn-start::after {
  border: none;
}

.btn-start:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.25);
}

.start-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 功能区域 */
.features-area {
  padding: 40rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 
    0 4rpx 20rpx rgba(14, 165, 233, 0.08),
    0 2rpx 8rpx rgba(14, 165, 233, 0.04);
  border: 2rpx solid #E0F2FE;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.feature-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 
    0 8rpx 28rpx rgba(14, 165, 233, 0.15),
    0 4rpx 12rpx rgba(14, 165, 233, 0.08);
}

.card-visual {
  position: relative;
  margin-right: 28rpx;
}

.visual-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.blue .visual-circle {
  background: linear-gradient(135deg, #38BDF8 0%, #0EA5E9 100%);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.3);
}

.orange .visual-circle {
  background: linear-gradient(135deg, #FB923C 0%, #F97316 100%);
  box-shadow: 0 8rpx 24rpx rgba(251, 146, 60, 0.3);
}

.visual-icon {
  font-size: 48rpx;
}

.visual-bg {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  opacity: 0.2;
  z-index: 0;
}

.blue .visual-bg {
  background: #38BDF8;
}

.orange .visual-bg {
  background: #FB923C;
}

.card-content {
  flex: 1;
}

.card-title {
  display: block;
  color: #1E293B;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  color: #64748B;
}

.card-action {
  display: flex;
  align-items: center;
  background: #F0F9FF;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
}

.action-text {
  color: #0EA5E9;
  font-weight: 600;
  font-size: 26rpx;
  margin-right: 8rpx;
}

.action-arrow {
  color: #0EA5E9;
  font-weight: 700;
  font-size: 28rpx;
}

/* 统计数据区域 */
.stats-area {
  padding: 0 40rpx 40rpx;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx 20rpx;
  box-shadow: 
    0 4rpx 20rpx rgba(14, 165, 233, 0.08),
    0 2rpx 8rpx rgba(14, 165, 233, 0.04);
  border: 2rpx solid #E0F2FE;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.stat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.stat-icon-wrap.blue {
  background: linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 100%);
}

.stat-icon-wrap.green {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.stat-icon-wrap.pink {
  background: linear-gradient(135deg, #FCE7F3 0%, #FBCFE8 100%);
}

.stat-icon {
  font-size: 36rpx;
}

.stat-value {
  display: block;
  color: #0EA5E9;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  color: #64748B;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #E0F2FE;
}

/* 底部提示区域 */
.hints-area {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 0 40rpx 60rpx;
  flex-wrap: wrap;
}

.hint-chip {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.08);
  border: 2rpx solid #E0F2FE;
}

.chip-emoji {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.chip-text {
  color: #64748B;
  font-size: 24rpx;
  font-weight: 500;
}

/* 大字体模式适配 */
.large-font .logo-icon {
  font-size: 100rpx;
}

.large-font .avatar {
  width: 120rpx;
  height: 120rpx;
}

.large-font .visual-circle {
  width: 112rpx;
  height: 112rpx;
}

.large-font .visual-icon {
  font-size: 56rpx;
}
