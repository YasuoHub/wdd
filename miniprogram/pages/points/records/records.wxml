<!--pages/points/records/records.wxml-->
<view class="container {{isLargeFont ? 'large-font' : ''}}">
  <!-- 背景 -->
  <view class="bg-blue">
    <view class="cloud cloud-1"></view>
    <view class="cloud cloud-2"></view>
    <view class="cloud cloud-3"></view>
  </view>

  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">积分明细</text>
  </view>

  <!-- 当前积分卡片 -->
  <view class="balance-card">
    <view class="balance-header">
      <text class="balance-label">当前积分</text>
      <text class="balance-frozen">冻结: {{frozen}}</text>
    </view>
    <view class="balance-value">{{balance}}</view>
    <view class="balance-available">可用: {{available}}</view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value income">+{{allStats.totalIncome}}</text>
      <text class="stat-label">累计收入</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value expense">-{{allStats.totalExpense}}</text>
      <text class="stat-label">累计支出</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{allStats.totalCount}}</text>
      <text class="stat-label">总记录</text>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-bar">
    <view
      class="filter-item {{currentFilter === item.key ? 'active' : ''}}"
      wx:for="{{filters}}"
      wx:key="key"
      bindtap="switchFilter"
      data-key="{{item.key}}"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="records-list">
    <view class="record-item" wx:for="{{records}}" wx:key="_id">
      <view class="record-icon">{{getTypeIcon(item.type)}}</view>
      <view class="record-content">
        <view class="record-header">
          <text class="record-title">{{item.description || getTypeName(item.type)}}</text>
          <text class="record-amount {{item.amount > 0 ? 'income' : 'expense'}}">
            {{item.amount > 0 ? '+' : ''}}{{item.amount}}
          </text>
        </view>
        <view class="record-footer">
          <text class="record-type">{{getTypeName(item.type)}}</text>
          <text class="record-time">{{item.formattedTime}}</text>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="loading-more" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && records.length > 0}}">
      <text>—— 没有更多了 ——</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无积分记录</text>
      <text class="empty-desc">快去赚取积分吧！</text>
    </view>
  </view>
</view>
