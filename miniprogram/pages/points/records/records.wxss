/**miniprogram/pages/points/records/records.wxss**/
/* 积分明细样式 */

page {
  background-color: #F0F9FF;
  min-height: 100vh;
}

.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 背景 */
.bg-blue {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(180deg, #0EA5E9 0%, #38BDF8 60%, #F0F9FF 100%);
  z-index: -1;
}

.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
}

.cloud-1 {
  width: 120rpx;
  height: 60rpx;
  top: 60rpx;
  left: 10%;
}

.cloud-2 {
  width: 180rpx;
  height: 90rpx;
  top: 30rpx;
  right: 15%;
}

.cloud-3 {
  width: 100rpx;
  height: 50rpx;
  top: 120rpx;
  left: 60%;
}

/* 页面标题 */
.page-header {
  padding-top: 20rpx;
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 当前积分卡片 */
.balance-card {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(14, 165, 233, 0.2);
}

.balance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.balance-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.balance-frozen {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.balance-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.balance-available {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.stat-value.income {
  color: #10B981;
}

.stat-value.expense {
  color: #EF4444;
}

.stat-label {
  font-size: 24rpx;
  color: #6B7280;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E5E7EB;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  padding: 12rpx 30rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #6B7280;
  box-shadow: 0 2rpx 10rpx rgba(14, 165, 233, 0.05);
  transition: all 0.3s ease;
}

.filter-item.active {
  background: #0EA5E9;
  color: #fff;
}

/* 记录列表 */
.records-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
}

.record-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 72rpx;
  height: 72rpx;
  background: #F0F9FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-content {
  flex: 1;
  min-width: 0;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  flex: 1;
  margin-right: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.record-amount.income {
  color: #10B981;
}

.record-amount.expense {
  color: #EF4444;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-type {
  font-size: 24rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 加载更多 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #6B7280;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E5E7EB;
  border-top-color: #0EA5E9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 大字体模式 */
.large-font .header-title {
  font-size: 46rpx;
}

.large-font .balance-value {
  font-size: 80rpx;
}

.large-font .balance-label,
.large-font .balance-frozen,
.large-font .balance-available {
  font-size: 30rpx;
}

.large-font .stat-value {
  font-size: 40rpx;
}

.large-font .record-title {
  font-size: 34rpx;
}

.large-font .record-amount {
  font-size: 36rpx;
}
