<!--miniprogram/pages/points/index/index.wxml-->
<view class="container {{isLargeFont ? 'large-font' : ''}}">
  <!-- 顶部蓝天白云装饰 -->
  <view class="sky-decoration">
    <view class="cloud cloud-1">☁️</view>
    <view class="cloud cloud-2">☁️</view>
    <view class="star">✨</view>
  </view>

  <!-- 积分显示卡片 - 游戏化设计 -->
  <view class="points-card">
    <view class="points-glow"></view>
    <view class="card-content">
      <view class="points-header">
        <text class="points-label">我的积分</text>
        <view class="total-badge">
          <text class="badge-text">累计 {{totalEarned}}</text>
        </view>
      </view>
      
      <view class="points-display">
        <text class="diamond-icon">💎</text>
        <text class="points-number {{isLargeFont ? 'font-xxl' : 'font-xl'}}">{{displayBalance || balance}}</text>
        <text class="points-unit">积分</text>
      </view>
      
      <view class="points-detail">
        <view class="detail-item">
          <text class="detail-dot frozen"></text>
          <text class="detail-text">冻结 {{frozen}}</text>
        </view>
        <view class="detail-divider"></view>
        <view class="detail-item">
          <text class="detail-dot available"></text>
          <text class="detail-text">可用 {{available}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 签到区域 - 游戏化设计 -->
  <view class="signin-card">
    <view class="signin-header">
      <view class="streak-badge">
        <text class="fire-icon">🔥</text>
        <text class="streak-text">连续签到 {{signInStreak}} 天</text>
      </view>
      <text class="reward-text">+{{todayReward}} 积分</text>
    </view>
    
    <!-- 7天进度可视化 -->
    <view class="week-progress">
      <view class="day-item" wx:for="{{[1,2,3,4,5,6,7]}}" wx:key="*this">
        <view class="day-circle {{signInStreak >= item ? 'active' : ''}} {{todaySignIn && signInStreak === item ? 'today' : ''}}">
          <text class="check-icon" wx:if="{{signInStreak >= item}}">✓</text>
          <text class="day-number" wx:else>{{item}}</text>
        </view>
        <text class="day-label">{{item === 7 ? '日' : '周' + item}}</text>
      </view>
    </view>
    
    <!-- 签到按钮 -->
    <button
      class="signin-btn {{todaySignIn ? 'signed' : ''}} {{isLargeFont ? 'btn-large' : ''}}"
      bindtap="signIn"
      disabled="{{todaySignIn}}"
    >
      <block wx:if="{{todaySignIn}}">
        <text class="btn-icon">✅</text>
        <text>今日已签到</text>
      </block>
      <block wx:else>
        <text class="btn-icon">🎁</text>
        <text>立即签到 +{{todayReward}}</text>
      </block>
    </button>
  </view>

  <!-- 快捷入口 - 横向卡片 -->
  <view class="quick-actions">
    <view class="action-card blue" bindtap="goToRecords">
      <view class="action-icon-wrap">
        <text class="action-icon">📋</text>
      </view>
      <view class="action-content">
        <text class="action-title">积分明细</text>
        <text class="action-desc">查看记录</text>
      </view>
      <view class="action-arrow">→</view>
    </view>
    
    <view class="action-card orange" bindtap="goToInvite">
      <view class="action-icon-wrap">
        <text class="action-icon">🎁</text>
      </view>
      <view class="action-content">
        <text class="action-title">邀请好友</text>
        <text class="action-desc">+50 积分</text>
      </view>
      <view class="action-arrow">→</view>
    </view>
  </view>

  <!-- 邀请码区域 -->
  <view class="invite-card">
    <view class="invite-header">
      <text class="invite-title">🎫 我的邀请码</text>
      <text class="invite-subtitle">好友注册双方都得50积分</text>
    </view>
    <view class="invite-code-box" bindtap="copyInviteCode">
      <text class="invite-code">{{inviteCode}}</text>
      <view class="copy-badge">
        <text class="copy-icon">📋</text>
        <text class="copy-text">点击复制</text>
      </view>
    </view>
    <button class="share-btn" open-type="share">
      <text class="share-icon">🔗</text>
      <text>分享邀请好友</text>
    </button>
  </view>

  <!-- 最近记录 - 时间线设计 -->
  <view class="records-section" wx:if="{{records.length > 0}}">
    <view class="section-header">
      <view class="header-left">
        <text class="section-icon">📈</text>
        <text class="section-title">最近记录</text>
      </view>
      <text class="view-all" bindtap="goToRecords">查看全部 →</text>
    </view>

    <view class="records-timeline">
      <view class="timeline-line"></view>
      <view class="record-item {{item.showAnimation ? 'show' : ''}}" 
            wx:for="{{records}}" 
            wx:key="_id"
            style="animation-delay: {{index * 100}}ms">
        <view class="timeline-dot {{item.type}}"></view>
        <view class="record-card">
          <view class="record-left">
            <view class="record-icon-wrap {{item.type}}">
              <text wx:if="{{item.type === 'task_reward'}}">💰</text>
              <text wx:elif="{{item.type === 'sign_in'}}">📅</text>
              <text wx:elif="{{item.type === 'invite'}}">🎁</text>
              <text wx:elif="{{item.type === 'register'}}">🎉</text>
              <text wx:elif="{{item.type === 'complete_profile'}}">✨</text>
              <text wx:else>📝</text>
            </view>
            <view class="record-info">
              <text class="record-title">{{item.description}}</text>
              <text class="record-time">{{item.formattedTime}}</text>
            </view>
          </view>
          <text class="record-amount {{item.amount > 0 ? 'positive' : 'negative'}}">
            {{item.amount > 0 ? '+' : ''}}{{item.amount}}
          </text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
    <view class="empty-icon">📭</view>
    <text class="empty-title">暂无积分记录</text>
    <text class="empty-desc">快去完成任务赚取积分吧！</text>
  </view>
</view>
