/**miniprogram/pages/points/invite/invite.wxss**/
/* 邀请好友样式 */

page {
  background-color: #F0F9FF;
  min-height: 100vh;
}

.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 背景 */
.bg-blue {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 350rpx;
  background: linear-gradient(180deg, #0EA5E9 0%, #38BDF8 60%, #F0F9FF 100%);
  z-index: -1;
}

.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
}

.cloud-1 {
  width: 120rpx;
  height: 60rpx;
  top: 60rpx;
  left: 10%;
}

.cloud-2 {
  width: 180rpx;
  height: 90rpx;
  top: 30rpx;
  right: 15%;
}

.cloud-3 {
  width: 100rpx;
  height: 50rpx;
  top: 120rpx;
  left: 60%;
}

/* 页面标题 */
.page-header {
  padding-top: 20rpx;
  margin-bottom: 30rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.header-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 邀请码卡片 */
.invite-code-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(14, 165, 233, 0.15);
}

.code-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.code-value {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  padding: 20rpx 50rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

/* 6位邀请码样式 */
.code-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.code-tip {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 分享按钮 */
.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin: 0 0 30rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.3);
}

.share-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 奖励说明 */
.reward-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
}

.reward-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.reward-item {
  display: flex;
  align-items: flex-start;
}

.reward-icon {
  width: 64rpx;
  height: 64rpx;
  background: #F0F9FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.reward-content {
  flex: 1;
}

.reward-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.reward-desc {
  font-size: 26rpx;
  color: #6B7280;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.stat-value.highlight {
  color: #10B981;
}

.stat-label {
  font-size: 24rpx;
  color: #6B7280;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E5E7EB;
}

/* 邀请记录 */
.records-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.08);
}

.records-list {
  margin-top: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.record-info {
  flex: 1;
}

.record-name {
  display: block;
  font-size: 30rpx;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.record-reward {
  font-size: 32rpx;
  font-weight: 700;
  color: #10B981;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(14, 165, 233, 0.2);
  border-top-color: #0EA5E9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 大字体模式 */
.large-font .header-title {
  font-size: 46rpx;
}

.large-font .header-desc {
  font-size: 30rpx;
}

.large-font .code-number {
  font-size: 56rpx;
}

.large-font .reward-title {
  font-size: 34rpx;
}

.large-font .stat-value {
  font-size: 40rpx;
}
