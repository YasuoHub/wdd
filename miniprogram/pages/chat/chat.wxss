/* pages/chat/chat.wxss */

page {
  background-color: #F5F5F5;
  height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 顶部导航栏 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: 50rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
}

.header-left, .header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon, .more-icon {
  font-size: 48rpx;
  color: #fff;
}

.header-center {
  flex: 1;
  text-align: center;
}

.chat-title {
  display: block;
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

.chat-status {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 加载中 */
.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(14, 165, 233, 0.2);
  border-top-color: #0EA5E9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

.load-more {
  text-align: center;
  padding: 20rpx 0;
}

.load-text {
  font-size: 24rpx;
  color: #999;
}

/* 时间分隔线 */
.time-divider {
  text-align: center;
  margin: 30rpx 0;
}

.time-text {
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.05);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 消息项 */
.message-item {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message-me {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-me .avatar {
  margin-left: 20rpx;
}

.message-other .avatar {
  margin-right: 20rpx;
}

.message-content {
  max-width: 65%;
  display: flex;
  flex-direction: column;
}

.message-me .message-content {
  align-items: flex-end;
}

.message-other .message-content {
  align-items: flex-start;
}

.sender-name {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

/* 消息气泡 */
.message-bubble {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  word-break: break-all;
}

.text-bubble {
  background: #fff;
}

.message-me .text-bubble {
  background: #0EA5E9;
}

.message-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

.message-me .message-text {
  color: #fff;
}

/* 图片气泡 */
.image-bubble {
  padding: 10rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.message-image {
  display: block;
  border-radius: 8rpx;
}

/* 系统消息 */
.system-message {
  text-align: center;
  margin: 20rpx 0;
}

.system-text {
  font-size: 24rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.05);
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.list-footer {
  height: 40rpx;
}

/* 底部操作栏 */
.bottom-bar {
  background: #fff;
  border-top: 1rpx solid #E5E5E5;
  padding: 20rpx 30rpx;
  padding-bottom: 40rpx;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.quick-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 32rpx;
  font-size: 26rpx;
  margin: 0;
  line-height: 1;
}

.quick-btn::after {
  border: none;
}

.complete-btn {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  color: #fff;
}

.support-btn {
  background: #F3F4F6;
  color: #6B7280;
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-wrapper {
  flex: 1;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.message-input {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

.input-placeholder {
  color: #999;
}

.input-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin: 0;
  padding: 0;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.image-btn {
  background: #F3F4F6;
  font-size: 36rpx;
}

.send-btn {
  background: #E5E7EB;
  color: #9CA3AF;
  transition: all 0.3s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  color: #fff;
}

/* 安全提示 */
.safety-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.tip-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 大字体模式 */
.large-font .message-text {
  font-size: 34rpx;
}

.large-font .message-input {
  font-size: 34rpx;
}