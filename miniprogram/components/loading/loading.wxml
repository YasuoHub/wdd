<!--components/loading/loading.wxml-->
<view wx:if="{{show}}" class="loading-wrapper {{mask ? 'with-mask' : ''}}">
  <view class="loading-content">
    <view wx:if="{{type === 'default'}}" class="loading-spinner"></view>
    <view wx:if="{{type === 'dots'}}" class="loading-dots">
      <view class="dot"></view>
      <view class="dot"></view>
      <view class="dot"></view>
    </view>
    <text wx:if="{{text}}" class="loading-text">{{text}}</text>
  </view>
</view>
