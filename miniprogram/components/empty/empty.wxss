/* components/empty/empty.wxss */
.empty-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  min-height: 400rpx;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-description {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.empty-button {
  padding: 20rpx 60rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
}

.empty-button::after {
  border: none;
}

.empty-button:active {
  opacity: 0.8;
}
